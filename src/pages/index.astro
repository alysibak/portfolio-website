---
import Base from "../layouts/Base.astro";
import ShellHint from "../components/ShellHint.astro";
import { navLinks, site } from "../lib/data";
---

<Base title="Aly Sibak" center>
  <div class="flex min-h-[calc(100vh-5rem)] flex-col justify-center px-6 md:px-8">
    <div class="mx-auto w-full max-w-xl">
      <h1 class="text-[2.25rem] font-medium leading-tight tracking-tight md:text-[2.5rem]">
        {site.name}<span class="cursor-blink" aria-hidden="true"></span>
      </h1>

      <p class="mt-5 text-[0.9375rem] text-muted">{site.roleLine}</p>
      <p class="mt-3 text-[0.9375rem] leading-relaxed text-muted">{site.now}</p>
      <p class="meta mt-2 text-subtle">{site.school}</p>

      <ShellHint variant="home" />

      <nav aria-label="Site" class="meta mt-10 flex flex-col gap-2.5 text-muted">
        {navLinks.map((link) => (
          <a href={link.href} class="link w-fit">{link.label}</a>
        ))}
        <a href={site.resume} target="_blank" rel="noopener noreferrer" class="link-accent w-fit">
          Resume ↗
        </a>
      </nav>
    </div>
  </div>
</Base>
