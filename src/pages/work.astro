---
import Base from "../layouts/Base.astro";
import ShellHint from "../components/ShellHint.astro";
import { projects } from "../lib/data";
---

<Base title="Work, Aly Sibak">
  <div class="mx-auto max-w-xl">
    <h1 class="text-2xl font-medium">Work</h1>
    <p class="mt-3 text-[0.9375rem] leading-relaxed text-muted">
      Selected projects, each one includes a bug I found, how I traced it, and what changed.
    </p>
    <ShellHint variant="work" />

    <ul class="mt-12 divide-y divide-border">
      {
        projects.map((project) => (
          <li class="py-10 first:pt-0 last:pb-0">
            <div class="flex items-baseline justify-between gap-4">
              <h2 class="text-[0.9375rem] font-medium">{project.title}</h2>
              <span class="meta shrink-0 tabular-nums text-subtle">{project.year}</span>
            </div>
            <p class="mt-2 text-[0.9375rem] leading-relaxed text-muted">{project.sentence}</p>
            <p
              class="inspectable meta mt-1 text-subtle"
              tabindex="0"
              data-diff={project.diff}
            >
              {project.stat}
            </p>

            {
              project.links.length > 0 && (
                <div class="meta mt-4 flex flex-wrap gap-x-4 gap-y-1">
                  {project.links.map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class:list={[
                        link.label === "Live" || link.label === "Devpost"
                          ? "link-accent"
                          : "link",
                      ]}
                    >
                      {link.label} ↗
                    </a>
                  ))}
                </div>
              )
            }

            <details class="case-file group mt-6">
              <summary class="meta cursor-pointer text-subtle select-none">
                <span class="link">case file</span>
              </summary>
              <dl class="mt-5 space-y-5">
                <div>
                  <dt class="meta text-subtle">Bug</dt>
                  <dd class="mt-1.5 text-[0.9375rem] leading-relaxed text-muted">{project.bug}</dd>
                </div>
                <div>
                  <dt class="meta text-subtle">Trace</dt>
                  <dd class="mt-1.5 text-[0.9375rem] leading-relaxed text-muted">{project.trace}</dd>
                </div>
                <div>
                  <dt class="meta text-subtle">Fix</dt>
                  <dd class="mt-1.5 text-[0.9375rem] leading-relaxed text-muted">{project.fix}</dd>
                </div>
                <div>
                  <dt class="meta text-subtle">Impact</dt>
                  <dd class="mt-1.5 text-[0.9375rem] leading-relaxed text-muted">{project.impact}</dd>
                </div>
              </dl>
            </details>
          </li>
        ))
      }
    </ul>

    <a href="/" class="meta mt-16 inline-block text-subtle link">← Home</a>
  </div>
</Base>
